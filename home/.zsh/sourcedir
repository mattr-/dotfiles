sourcedir() {
  if [ ! -d "$1" ]; then
    echo "no such directory: $1"
    return 1
  fi

  # List plain files and symlinks, setting the NULL_GLOB option for each pattern
  # . - plain files
  # @ - symlinks
  # NULL_GLOB prevents warnings when nothing exists to glob
  for f in "$1"/*(.N,@N); do
    case "$f" in
      # Don't execute backup, old, swap, compiled, or disabled files
      *~|*.bak|*.old|*.sw?|*.zwc|*.disabled) continue;;
    esac

    source "$f"
  done
}

